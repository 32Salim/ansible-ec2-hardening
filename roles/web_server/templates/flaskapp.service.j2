[Unit]
Description=Gunicorn service for Flask app
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/flaskapp/app
Environment="PATH=/opt/flaskapp/venv/bin"
ExecStart=/opt/flaskapp/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 app:app
Restart=always

[Install]
WantedBy=multi-user.target
